# Copy to .env and fill in.
# Used by n8nac and as injection source for n8n credentials during sync.

# === n8n Instance ===
N8N_API_URL=https://your-n8n-instance.example.com
N8N_API_KEY=
N8N_USER=user@example.com

# === LLM Providers ===
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# === Messaging ===
SLACK_BOT_TOKEN=
TELEGRAM_BOT_TOKEN=

# === Databases ===
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=

# === Vector Store ===
QDRANT_URL=
QDRANT_API_KEY=

# === Integrations (add as needed) ===
NOTION_API_KEY=
FIRECRAWL_API_KEY=
