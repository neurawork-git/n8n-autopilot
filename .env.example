# n8n MCP Template - Environment Variables
# Copy to .env and fill with your values

# === n8n Instance ===
# Used by: n8nac CLI for sync/test
N8N_API_URL=https://your-n8n-instance.app.n8n.cloud
N8N_API_KEY=
N8N_USER=user@example.com

# === API Keys (for n8n credentials) ===

# LLM Providers
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Messaging
SLACK_BOT_TOKEN=xoxb-...
TELEGRAM_BOT_TOKEN=

# Databases (local Docker defaults)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=n8n_local
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Vector Store
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# APIs — Core Integrations
CLOSE_API_KEY=
FIRECRAWL_API_KEY=
SERP_API_KEY=
APIFY_API_TOKEN=
NOTION_API_KEY=

# APIs — Community Nodes
FIREFLIES_API_KEY=
EASYBILL_API_KEY=
PANDADOC_API_KEY=
AWORK_API_KEY=
# SOAP_WSDL_URL=https://example.com/service?wsdl

# Notion Advanced (extends core Notion)
# NOTION_LEADS_DB_ID=              # Used by close_crm_lead_to_notion example

# MCP Client (community node — connects to external MCP servers)
# MCP_SERVER_URL=http://localhost:3000

# === Optional ===
# WEBHOOK_PATH=
# WORKFLOW_ID=
# MAX_REQUESTS_PER_MINUTE=100
# LOG_LEVEL=info
