# macOS
.DS_Store

# Node
node_modules/

# n8n config (contains API keys — never commit)
.env
.env.local
.mcp.json

# n8nac — runtime-generated by `npx n8nac init` / `init-auth` / `init-project`
n8nac-config.json
n8nac-instance.json

# n8nac — sync state + journal (regenerated by push/pull)
.n8n-state.json
workflows/**/.n8n-state.json
workflows/**/.n8n-sync-events.jsonl

# n8nac — generated TypeScript stubs (always regenerated on sync)
workflows/**/n8n-workflows.d.ts
workflows/**/tsconfig.json

# n8nac — auto-generated AI context (run `npx n8nac update-ai` to regenerate)
AGENTS.md
.agents/

# Workflows (template repo — user-created workflows are not tracked)
/workflows/

# TypeScript
dist/
*.tsbuildinfo

# Compiled workflow output
/out/

# Node schema cache — instance-specific (community nodes vary per user).
# Run `/n8n-autopilot:pull-schemas` after first clone to populate.
schemas/nodes/*.json
schemas/nodes/**/*.json
schemas/_index.json
!schemas/nodes/.gitkeep

# Editor / IDE
.vscode/
.idea/
.cursor/

# n8n-as-code AI helpers
n8nac-skills
n8nac-skills.cmd

# Local Claude Code settings (personal permissions, paths)
.claude/settings.json
.claude/settings.local.json

# Internal strategy notes — not part of the public plugin distribution
docs/STRATEGIC_ANALYSIS.md

# Autopilot feedback runtime store (may contain repo-specific detail — never commit; PII risk)
.n8n-autopilot/

# Transient harness lock
.claude/scheduled_tasks.lock
